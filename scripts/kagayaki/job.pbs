#!/bin/bash
#PBS -N Job_with_Notify
#PBS -q SMALL
#PBS -l select=1:ncpus=1:mem=2gb
#PBS -j oe
#PBS -o log/

# --------------------------------------------------------------------------
# 環境設定
# --------------------------------------------------------------------------
cd "$PBS_O_WORKDIR"

# ログ用ディレクトリを念のため作成
mkdir -p log

# .env から設定を読み込む (Webhook URL用)
if [ -f "scripts/.env" ]; then
    source "scripts/.env"
fi

# --- 設定: 実行したいコマンドをここに書く ---
CMD="python3 test.py"
# ----------------------------------------

echo "Job Start at: $(date)"


# --------------------------------------------------------------------------
# プログラムの実行
# --------------------------------------------------------------------------
echo ">>> Running: ${CMD}"
${CMD}
EXIT_CODE=$?

echo "Job End at: $(date)"

# --------------------------------------------------------------------------
# Discord通知の送信
# --------------------------------------------------------------------------
NOTIFY="./scripts/kagayaki/notify.sh"
chmod +x "${NOTIFY}"
"${NOTIFY}" $EXIT_CODE "$CMD"
