#!/bin/bash
#SBATCH --job-name=Dual_Emp_Train
#SBATCH --partition=GPU-1
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=4
#SBATCH --mem=16G
#SBATCH --gres=gpu:1
#SBATCH --output=%j.out

# --------------------------------------------------------------------------
# 環境設定
# --------------------------------------------------------------------------
cd "$SLURM_SUBMIT_DIR"

# ログ用ディレクトリを念のため作成
mkdir -p log

# .env から設定を読み込む (Webhook URL用)
if [ -f "scripts/.env" ]; then
    source "scripts/.env"
fi

# uv のパスを通す（インストール先が ~/.local/bin の場合）
export PATH="$HOME/.local/bin:$PATH"

# 環境の同期（pyproject.toml に基づいて依存パッケージをインストール）
uv sync

CMD_EVAL="uv run python -m src.run_all --eval_only --checkpoint checkpoints/run_20260410_1653/best_model.pt --max_gen_len 30 --device cuda"

echo "Job Start at: $(date)"


# --------------------------------------------------------------------------
# プログラムの実行
# --------------------------------------------------------------------------
# Issue #22: 評価のみ（学習・label_emotions.py は不要）
echo ">>> Running: ${CMD_EVAL}"
${CMD_EVAL}
EXIT_CODE=$?

echo "Job End at: $(date)"

# --------------------------------------------------------------------------
# Discord通知の送信
# --------------------------------------------------------------------------
NOTIFY="./scripts/hakusan/notify.sh"
chmod +x "${NOTIFY}"
"${NOTIFY}" $EXIT_CODE "$CMD_EVAL"
